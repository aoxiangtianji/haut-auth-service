# --- Rust ---
# Build output. Cargo.lock is committed on purpose: this is a binary crate and
# the OpenWrt Makefile copies Cargo.lock into the build dir for reproducible builds.
target/
**/*.rs.bk
*.pdb

# --- OpenWrt build artifacts ---
# Generated when building inside an SDK / buildroot tree. Anchored to the repo
# root so source dirs like etc/config are never accidentally ignored.
/bin/
/build_dir/
/staging_dir/
/dl/
/feeds/
/tmp/
*.ipk
*.apk

# --- Secrets / local config ---
# Never commit real credentials (the Srun portal needs username/password).
.env
*.local

# --- OS files ---
.DS_Store
Thumbs.db

# --- Editor / IDE ---
.idea/
.vscode/
*.swp
*.swo
*~

# --- Project Specific ---
*.html
